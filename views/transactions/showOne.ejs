<% layout("layouts/boilerplate") %>

    <div class="container-fluid">

        <!-- Header -->
        <div class="row mb-4 align-items-center">
            <div class="col">
                <h1 class="h2 mb-1">Transaction Details</h1>
                <p class="text-muted mb-0">View complete expense information</p>
            </div>
            <div class="col text-end">
                <a href="/transactions" class="btn btn-outline-secondary">
                    ← Back to Transactions
                </a>
            </div>
        </div>

        <!-- Transaction Card -->
        <div class="row justify-content-center">
            <div class="col-md-8 col-lg-6">
                <div class="card border-0 shadow-sm">
                    <div class="card-body p-4">

                        <!-- Amount -->
                        <div class="text-center mb-4">
                            <h2 class="fw-bold mb-1">
                                ₹<%= transaction.amount.toLocaleString("en-IN") %>
                            </h2>
                            <span class="badge bg-light text-dark border">
                                <%= transaction.category %>
                            </span>
                        </div>

                        <!-- Details -->
                        <ul class="list-group list-group-flush mb-4">

                            <li class="list-group-item d-flex justify-content-between px-0">
                                <span class="text-muted">Description</span>
                                <span class="fw-medium">
                                    <%= transaction.description %>
                                </span>
                            </li>

                            <li class="list-group-item d-flex justify-content-between px-0">
                                <span class="text-muted">Date</span>
                                <span>
                                    <%= transaction.date.toLocaleDateString("en-IN", { day: "2-digit" , month: "short" ,
                                        year: "numeric" }) %>
                                </span>
                            </li>

                            <li class="list-group-item d-flex justify-content-between px-0">
                                <span class="text-muted">Category</span>
                                <span>
                                    <%= transaction.category %>
                                </span>
                            </li>

                            <% if (transaction.receipt && transaction.receipt.url) { %>
                                <li class="list-group-item d-flex justify-content-between align-items-center px-0">
                                    <span class="text-muted">Receipt</span>
                                    <a href="<%= transaction.receipt.url %>" target="_blank" class="btn btn-sm btn-outline-secondary">
                                        <i class="fas fa-receipt me-1"></i>View Receipt
                                    </a>
                                </li>
                            <% } %>

                        </ul>

                        <!-- Actions -->
                        <div class="d-flex justify-content-end gap-2">

                            <form action="/transactions/<%= transaction._id %>/edit" method="GET">
                                <button class="btn btn-sm btn-outline-primary">
                                    Edit
                                </button>
                            </form>

                            <form action="/transactions/<%= transaction._id %>?_method=DELETE" method="POST"
                                onsubmit="return confirm('Are you sure you want to delete this transaction?')">
                                <button class="btn btn-sm btn-outline-danger">
                                    Delete
                                </button>
                            </form>

                        </div>

                    </div>
                </div>
            </div>
        </div>

    </div>
