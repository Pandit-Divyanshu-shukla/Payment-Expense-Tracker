<% layout("layouts/boilerplate") %>

<div class="container-fluid">

  <!-- Header -->
  <div class="row mb-4">
    <div class="col">
      <h1 class="h2 mb-1">All Transactions</h1>
      <p class="text-muted mb-0">Complete list of your expenses</p>
    </div>
    <div class="col text-end">
      <a href="/dashboard" class="btn btn-outline-secondary">
        ← Back to Dashboard
      </a>
    </div>
  </div>

  

  <!-- Transactions Table -->
  <div class="card border-0 shadow-sm">
    <div class="card-body p-0">

      <% if (transactions.length === 0) { %>
        <div class="text-center py-5">
          <i class="fas fa-receipt fa-3x text-muted opacity-25 mb-3"></i>
          <h5 class="text-muted">No transactions found</h5>
          <p class="text-muted mb-3">Start by adding an expense</p>
          <a href="/transactions/new" class="btn btn-primary">
            <i class="fas fa-plus me-1"></i>Add Expense
          </a>
        </div>
      <% } else { %>

      <div class="table-responsive">
        <table class="table table-hover mb-0">
          <thead class="table-light">
            <tr>
              <th class="ps-4">Date</th>
              <th>Description</th>
              <th>Category</th>
              <th class="text-end">Amount</th>
              <th class="text-end">Actions</th>
            </tr>
          </thead>

          <tbody>
            <% transactions.forEach(txn => { %>
              <tr>
                <td class="ps-4">
                  <i class="fas fa-calendar-day text-muted me-2"></i>
                  <%= txn.date.toLocaleDateString("en-IN", {
                    day: "2-digit",
                    month: "short",
                    year: "numeric"
                  }) %>
                </td>

                <td class="fw-medium">
                  <%= txn.description %>
                </td>

                <td>
                  <span class="badge bg-light text-dark border">
                    <%= txn.category %>
                  </span>
                </td>

                <td class="text-end fw-semibold">
                  ₹<%= txn.amount.toLocaleString("en-IN") %>
                </td>

                <td class="text-end">
                  <div class="d-inline-flex gap-2">
                    <form action="/transactions/<%= txn._id %>/edit" method="GET">
                      <button class="btn btn-sm btn-outline-primary">
                        Edit
                      </button>
                    </form>

                    <form
                      action="/transactions/<%= txn._id %>?_method=DELETE"
                      method="POST"
                      onsubmit="return confirm('Are you sure you want to delete this transaction?')">
                      <button class="btn btn-sm btn-outline-danger">
                        Delete
                      </button>
                    </form>
                  </div>
                </td>
              </tr>
            <% }) %>
          </tbody>
        </table>
      </div>

      <% } %>
    </div>
  </div>

  

  <!-- Quick Action -->
  <div class="row mt-4">
    <div class="col text-end">
      <a href="/transactions/new" class="btn btn-primary">
        <i class="fas fa-plus-circle me-2"></i>Add New Expense
      </a>
    </div>
  </div>

</div>
